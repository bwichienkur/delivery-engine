  <eidw:InstantPostWF.Implementation>
    <Sequence DisplayName="Realtime POST Sequence" sad:XamlDebuggerXmlReader.FileName="C:\TFS_NEXUS\Nexus\LeadDeliveryVerification\src\WorkFlow\DE\InstantPostWF.xaml">
      <Sequence.Variables>
        <Variable x:TypeArguments="x:String" Name="PostResponse" />
        <Variable x:TypeArguments="x:String" Name="ServerResponseCode" />
        <Variable x:TypeArguments="x:Boolean" Name="PostSuccessful" />
        <Variable x:TypeArguments="x:String" Name="PostData" />
