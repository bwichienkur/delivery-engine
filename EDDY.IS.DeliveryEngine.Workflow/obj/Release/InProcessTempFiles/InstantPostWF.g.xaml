      </Assign>
      <enbda:WriteToDELog WriteToDELogStatus="{x:Null}" ActivityStepId="0" DeliveryEndpointId="[Endpoint.DeliveryEndpointId]" DeliveryEngineEventId="10" LeadData="[LeadData]" Message="[&quot;Incrementing Attempt count to &quot; + RealtimeDeliveryItem.CurrentDeliveryAttempts.ToString()]" Verbosity="7" />
      <Assign DisplayName="Update Last POST Atempt DateTime">
        <Assign.To>
          <OutArgument x:TypeArguments="s:DateTime">[RealtimeDeliveryItem.LastDeliveryAttemptDatetime]</OutArgument>
        </Assign.To>
        <Assign.Value>
          <InArgument x:TypeArguments="s:DateTime">[DateTime.Now.ToUniversalTime()]</InArgument>
        </Assign.Value>
      </Assign>
