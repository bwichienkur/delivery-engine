      <If Condition="[PostSuccessful]">
        <If.Then>
          <Sequence DisplayName="POST Success Sequence">
            <enbda:LogSuccessfulPost LogSuccessfulPostStatus="{x:Null}" Endpoint="[Endpoint]" LeadData="[LeadData]" PostData="[PostData]" PostResponse="[PostResponse]" RDQ="[RealtimeDeliveryItem]" RejectionReasonID="[_RejectionReasonID]" ReviewedStatusID="[_ReviewedStatusID]" SchoolValidationResponseStatusID="[_SchoolResponseStatus]" ServerResponseCode="[ServerResponseCode]" />
            <enbda:RemoveRDQItem RemoveRDQItemStatus="{x:Null}" IsBeta="[IsBeta]" RDQ="[RealtimeDeliveryItem]" />
            <enbda:WriteToDELog WriteToDELogStatus="{x:Null}" ActivityStepId="280" DeliveryEndpointId="[Endpoint.DeliveryEndpointId]" DeliveryEngineEventId="10" LeadData="[LeadData]" Message="Post Success. Removing RDQ Item." Verbosity="5" />
