              <If.Else>
                <Sequence DisplayName="Max Attempts Not Reached">
                  <enbda:UpdateRDQFailedStatus RDQFailedStatus="{x:Null}" Endpoint="[Endpoint]" RDQ="[RealtimeDeliveryItem]" />
                  <enbda:WriteToDELog WriteToDELogStatus="{x:Null}" ActivityStepId="290" DeliveryEndpointId="[Endpoint.DeliveryEndpointId]" DeliveryEngineEventId="370" LeadData="[LeadData]" Message="[&quot;Post attempt &quot; + RealtimeDeliveryItem.CurrentDeliveryAttempts.ToString() + &quot; Failed. Max Attempts of &quot; + Endpoint.MaxRetryAttempts.ToString() + &quot;Not Reached. RDQ Updated to rety at: &quot; + RealtimeDeliveryItem.NextDeliveryAttemptDatetime.ToString() + &quot;.&quot;]" Verbosity="5" />
                  <Assign DisplayName="Assign Return Status">
                    <Assign.To>
                      <OutArgument x:TypeArguments="x:Int32">[RealtimePostDeliveryStatus]</OutArgument>
                    </Assign.To>
                    <Assign.Value>
                      <InArgument x:TypeArguments="x:Int32">515</InArgument>
                    </Assign.Value>
                  </Assign>
                </Sequence>
              </If.Else>
            </If>
          </Sequence>
        </If.Else>
      </If>
      <Assign>
        <Assign.To>
          <OutArgument x:TypeArguments="x:Int32">[SchoolValidationResponseStatus]</OutArgument>
        </Assign.To>
        <Assign.Value>
          <InArgument x:TypeArguments="x:Int32">[_SchoolResponseStatus]</InArgument>
