        <Variable x:TypeArguments="x:Boolean" Name="IsBeta" />
        <Variable x:TypeArguments="x:Int32" Name="_RejectionReasonID" />
        <Variable x:TypeArguments="x:Int32" Name="_ReviewedStatusID" />
      </Sequence.Variables>
      <Assign>
        <Assign.To>
          <OutArgument x:TypeArguments="x:Boolean">[IsBeta]</OutArgument>
