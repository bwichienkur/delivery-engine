              <Assign.To>
                <OutArgument x:TypeArguments="x:Int32">[RealtimePostDeliveryStatus]</OutArgument>
              </Assign.To>
              <Assign.Value>
                <InArgument x:TypeArguments="x:Int32">600</InArgument>
              </Assign.Value>
            </Assign>
          </Sequence>
        </If.Then>
        <If.Else>
          <Sequence DisplayName="POST Failed Sequence">
            <enbda:LogFailedPost logStatus="{x:Null}" Endpoint="[Endpoint]" LeadData="[LeadData]" PostData="[PostData]" PostResponse="[PostResponse]" RDQ="[RealtimeDeliveryItem]" RejectionReasonID="[_RejectionReasonID]" ReviewedStatusID="[_ReviewedStatusID]" SchoolValidationResponseStatusID="[_SchoolResponseStatus]" ServerResponseCode="[ServerResponseCode]" />
            <If Condition="[RealtimeDeliveryItem.CurrentDeliveryAttempts &gt;= Endpoint.MaxRetryAttempts]">
              <If.Then>
                <Sequence DisplayName="Max Attempts Reached">
                  <enbda:RemoveRDQItem RemoveRDQItemStatus="{x:Null}" IsBeta="[IsBeta]" RDQ="[RealtimeDeliveryItem]" />
                  <enbda:WriteToDELog WriteToDELogStatus="{x:Null}" ActivityStepId="300" DeliveryEndpointId="[Endpoint.DeliveryEndpointId]" DeliveryEngineEventId="370" LeadData="[LeadData]" Message="Post Failed. Max Attempts Reached. Removing RDQ Item." Verbosity="5" />
                  <Assign DisplayName="Assign Return Status">
                    <Assign.To>
                      <OutArgument x:TypeArguments="x:Int32">[RealtimePostDeliveryStatus]</OutArgument>
