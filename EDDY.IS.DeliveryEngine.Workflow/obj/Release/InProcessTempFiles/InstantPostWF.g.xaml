      <enbda:CreatePostData Endpoint="[Endpoint]" LeadData="[LeadData]" PostData="[PostData]" />
      <enbda:WriteToDELog WriteToDELogStatus="{x:Null}" ActivityStepId="240" DeliveryEndpointId="[Endpoint.DeliveryEndpointId]" DeliveryEngineEventId="10" LeadData="[LeadData]" Message="[&quot;Created Post data: &quot; + PostData]" Verbosity="5" />
      <enbda:DeliverInstantPost Endpoint="[Endpoint]" LeadData="[LeadData]" PostData="[PostData]" PostResponse="[PostResponse]" ServerResponse="[ServerResponseCode]" />
      <enbda:WriteToDELog WriteToDELogStatus="{x:Null}" ActivityStepId="260" DeliveryEndpointId="[Endpoint.DeliveryEndpointId]" DeliveryEngineEventId="10" LeadData="[LeadData]" Message="[&quot;Posted Data - Post response - Code: &quot; + ServerResponseCode.ToString()]" Verbosity="2" />
      <enbda:WriteToDELog WriteToDELogStatus="{x:Null}" ActivityStepId="260" DeliveryEndpointId="[Endpoint.DeliveryEndpointId]" DeliveryEngineEventId="10" LeadData="[LeadData]" Message="[&quot;Posted Data - Post response: &quot; + PostResponse]" Verbosity="2" />
      <Assign DisplayName="Increment Attempts Count">
        <Assign.To>
          <OutArgument x:TypeArguments="x:Int32">[RealtimeDeliveryItem.CurrentDeliveryAttempts]</OutArgument>
