<?xml version="1.0" encoding="utf-8"?>
<local:RealtimeEndpointWF mva:VisualBasic.Settings="Assembly references and imported namespaces for internal implementation" xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities" xmlns:enbda="clr-namespace:EDDY.IS.DeliveryEngine.Workflow.Activities;assembly=EDDY.IS.DeliveryEngine.Workflow.Activities" xmlns:enec="clr-namespace:EDDY.IS.DeliveryEngine.Entity;assembly=EDDY.IS.DeliveryEngine.Entity" xmlns:enec1="clr-namespace:EDDY.IS.DeliveryEngine.Entity.Common;assembly=EDDY.IS.DeliveryEngine.Entity" xmlns:eneic="clr-namespace:EDDY.IS.DeliveryEngine.Entity.Interface.Common;assembly=EDDY.IS.DeliveryEngine.Entity" xmlns:local="clr-namespace:EDDY.IS.DeliveryEngine.Workflow;assembly=EDDY.IS.DeliveryEngine.Workflow" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:mv="clr-namespace:Microsoft.VisualBasic;assembly=System" xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities" xmlns:s="clr-namespace:System;assembly=mscorlib" xmlns:s1="clr-namespace:System;assembly=System" xmlns:s2="clr-namespace:System;assembly=System.Xml" xmlns:s3="clr-namespace:System;assembly=System.Core" xmlns:s4="clr-namespace:System;assembly=System.ServiceModel" xmlns:sa="clr-namespace:System.Activities;assembly=System.Activities" xmlns:sad="clr-namespace:System.Activities.Debugger;assembly=System.Activities" xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation" xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System" xmlns:scg1="clr-namespace:System.Collections.Generic;assembly=System.ServiceModel" xmlns:scg2="clr-namespace:System.Collections.Generic;assembly=System.Core" xmlns:scg3="clr-namespace:System.Collections.Generic;assembly=mscorlib" xmlns:sd="clr-namespace:System.Data;assembly=System.Data" xmlns:sl="clr-namespace:System.Linq;assembly=System.Core" xmlns:st="clr-namespace:System.Text;assembly=mscorlib" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <local:RealtimeEndpointWF.Implementation>
    <Sequence sad:XamlDebuggerXmlReader.FileName="C:\TFS_NEXUS\Nexus\LeadDeliveryVerification\src\WorkFlow\DE\RealtimeEndpointWF.xaml">
      <Sequence.Variables>
        <Variable x:TypeArguments="s:DateTime" Name="NextDeliveryAttemptDatetime" />
        <Variable x:TypeArguments="x:Boolean" Name="IsBlackedOut" />
        <Variable x:TypeArguments="x:Int32" Name="_SchoolResponseStatus" />
        <Variable x:TypeArguments="x:Int32" Name="_ReviewedStatusID" />
      </Sequence.Variables>
      <enbda:CheckEndpointBlackout DeliveryEndpoint="[DeliveryEndpoint]" IsBlackedOut="[IsBlackedOut]" NextDeliveryAttemptDateTime="[NextDeliveryAttemptDatetime]" />
      <If Condition="[IsBlackedOut]" DisplayName="Is Endpoint Currently Blacked Out?">
        <If.Then>
          <Sequence DisplayName="Endpoint Blacked Out Sequence">
            <enbda:WriteToDELog WriteToDELogStatus="{x:Null}" ActivityStepId="220" DeliveryEndpointId="[DeliveryEndpoint.DeliveryEndpointId]" DeliveryEngineEventId="10" LeadData="[LeadData]" Message="[&quot;Endpoint: &quot; + DeliveryEndpoint.DeliveryEndpointId.ToString() + &quot; currently blacked out.&quot;]" Verbosity="3" />
            <enbda:UpdateRDQForBlackout UpdateRDQForBlackoutStatus="{x:Null}" NextDeliveryAttemptDatetime="[NextDeliveryAttemptDatetime]" RDQ="[RDQItem]" />
            <enbda:WriteToDELog WriteToDELogStatus="{x:Null}" ActivityStepId="0" DeliveryEndpointId="[DeliveryEndpoint.DeliveryEndpointId]" DeliveryEngineEventId="10" LeadData="[LeadData]" Message="[&quot;Endpoint: &quot; + DeliveryEndpoint.DeliveryEndpointId.ToString() + &quot;Updating RDQ for blackout. Next Delivery Attempt set for: &quot; + NextDeliveryAttemptDatetime.ToString()]" Verbosity="5" />
            <Assign DisplayName="Assign Return Status">
              <Assign.To>
                <OutArgument x:TypeArguments="x:Int32">[RealtimeEndpointDeliveryStatus]</OutArgument>
              </Assign.To>
              <Assign.Value>
                <InArgument x:TypeArguments="x:Int32">516</InArgument>
              </Assign.Value>
            </Assign>
            <Assign>
              <Assign.To>
                <OutArgument x:TypeArguments="x:Int32">[SchoolValidationResponseStatus]</OutArgument>
              </Assign.To>
              <Assign.Value>
                <InArgument x:TypeArguments="x:Int32">200</InArgument>
              </Assign.Value>
            </Assign>
          </Sequence>
        </If.Then>
        <If.Else>
          <Switch x:TypeArguments="enec:LeadDeliveryType" Expression="[DeliveryEndpoint.DeliveryType]">
            <Sequence x:Key="InstantPost" DisplayName="Realtime Post Sequence">
              <enbda:WriteToDELog WriteToDELogStatus="{x:Null}" ActivityStepId="85" DeliveryEndpointId="[DeliveryEndpoint.DeliveryEndpointId]" DeliveryEngineEventId="10" LeadData="[LeadData]" Message="[&quot;Calling InstantPostWF for Endpoint: &quot; + DeliveryEndpoint.DeliveryEndpointId.ToString() + &quot;.&quot;]" Verbosity="3" />
              <local:InstantPostWF Endpoint="[DeliveryEndpoint]" LeadData="[LeadData]" RealtimeDeliveryItem="[RDQItem]" RealtimePostDeliveryStatus="[RealtimeEndpointDeliveryStatus]" ReviewedDeliveryStatusID="[_ReviewedStatusID]" SchoolValidationResponseStatus="[_SchoolResponseStatus]" />
            </Sequence>
            <Sequence x:Key="InstantEmail" DisplayName="Realtime Email Sequence">
              <enbda:WriteToDELog WriteToDELogStatus="{x:Null}" ActivityStepId="85" DeliveryEndpointId="[DeliveryEndpoint.DeliveryEndpointId]" DeliveryEngineEventId="10" LeadData="[LeadData]" Message="[&quot;Calling InstantEmailWF for Endpoint: &quot; + DeliveryEndpoint.DeliveryEndpointId.ToString() + &quot;.&quot;]" Verbosity="3" />
              <local:InstantEmailWF Endpoint="[DeliveryEndpoint]" LeadData="[LeadData]" RealtimeDeliveryItem="[RDQItem]" RealtimeEmailDeliveryStatus="[RealtimeEndpointDeliveryStatus]" SchoolValidationResponseStatus="[_SchoolResponseStatus]" />
            </Sequence>
          </Switch>
        </If.Else>
      </If>
      <If Condition="[RDQItem.CurrentDeliveryAttempts &gt;= 1 And RealtimeEndpointDeliveryStatus &gt;= 600]" DisplayName="If this was a retry AND the endpoint is finished for this lead, check if its last and if so, update lead realtime status">
        <If.Then>
          <Sequence>
            <Sequence.Variables>
              <Variable x:TypeArguments="x:Boolean" Name="LeadRealtimeDeliveriesComplete" />
            </Sequence.Variables>
            <enbda:UpdateLeadStatusIfLastRealtimeDelivery EndPoint="[DeliveryEndpoint]" IsBeta="[LeadData.IsBeta]" LeadId="[LeadData.LeadId]" LeadRealtimeDeliveryStatus="[RealtimeEndpointDeliveryStatus]" ReviewedStatusID="[_ReviewedStatusID]" SchoolValidationResponseStatus="[_SchoolResponseStatus]" WasLastRealtimeDelivery="[LeadRealtimeDeliveriesComplete]" />
            <If Condition="[LeadRealtimeDeliveriesComplete]">
              <If.Then>
                <enbda:WriteToDELog WriteToDELogStatus="{x:Null}" ActivityStepId="100" DeliveryEndpointId="[DeliveryEndpoint.DeliveryEndpointId]" DeliveryEngineEventId="10" DisplayName="Log Updated Lead to Complete" LeadData="[LeadData]" Message="[&quot;Endpoint: &quot; + DeliveryEndpoint.DeliveryEndpointId.ToString() + &quot; was the final realtime endpoint for LeadId: &quot; + LeadData.LeadId.ToString() + &quot;. Updated RealtimeDeliveryStatus to 200.&quot;]" Verbosity="5" />
              </If.Then>
            </If>
          </Sequence>
        </If.Then>
      </If>
      <Assign>
        <Assign.To>
          <OutArgument x:TypeArguments="x:Int32">[SchoolValidationResponseStatus]</OutArgument>
        </Assign.To>
        <Assign.Value>
          <InArgument x:TypeArguments="x:Int32">[_SchoolResponseStatus]</InArgument>
        </Assign.Value>
      </Assign>
      <Assign>
        <Assign.To>
          <OutArgument x:TypeArguments="x:Int32">[ReviewedStatusID]</OutArgument>
        </Assign.To>
        <Assign.Value>
          <InArgument x:TypeArguments="x:Int32">[_ReviewedStatusID]</InArgument>
        </Assign.Value>
      </Assign>
    </Sequence>
  </local:RealtimeEndpointWF.Implementation>
</local:RealtimeEndpointWF>